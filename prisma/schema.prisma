generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model HouseholdProfile {
  id               Int      @id
  taxYear          Int
  filingStatus     String
  hasDigitalAssets Boolean  @default(false)
  primaryTaxpayer  String
  stateResidence   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ImportedDocument {
  id             String        @id
  fileName       String
  storedFileName String
  fileSizeBytes  Int
  mimeType       String
  kind           String
  status         String
  taxYear        Int
  importedAt     DateTime
  extractedFields ExtractedField[]
  extractions    DocumentExtraction[]
  gaps           DataGap[]
  missingFacts   MissingFact[]
  questionnaireResponses QuestionnaireResponse[]
  assetLots      AssetLot[]

  @@index([importedAt])
  @@index([taxYear])
}

model MissingFact {
  id         String           @id
  documentId String
  sequence   Int
  key        String
  label      String
  reason     String
  severity   String
  document   ImportedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@unique([documentId, sequence])
}

model AssetLot {
  id               String            @id
  accountName      String
  acquiredOn       String
  assetKind        String
  assetKey         String
  costBasisInCents Int
  displayName      String
  holdingTerm      String
  quantity         String
  sourceDocumentId String?
  sourceDocument   ImportedDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([assetKey, acquiredOn])
  @@index([sourceDocumentId])
}

model DocumentExtraction {
  id            String           @id
  documentId    String
  extractorKey  String
  status        String
  statusMessage String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  parsedAt      DateTime?
  document      ImportedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields        ExtractedField[]

  @@index([documentId])
  @@index([status])
}

model ExtractedField {
  id             String             @id
  extractionId   String
  documentId     String
  key            String
  label          String
  valueType      String
  rawValue       String
  normalizedValue String?
  confidence     String
  taxRelevance   String
  isMissing      Boolean            @default(false)
  sourcePage     Int?
  provenanceHint String?
  extraction     DocumentExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  document       ImportedDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  gaps           DataGap[]

  @@index([documentId])
  @@index([extractionId])
}

model DataGap {
  id              String          @id
  documentId      String?
  extractedFieldId String?
  gapKind         String
  key             String
  title           String
  description     String
  severity        String
  status          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  document        ImportedDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedField  ExtractedField? @relation(fields: [extractedFieldId], references: [id], onDelete: SetNull)
  questionnaireResponses QuestionnaireResponse[]

  @@index([documentId])
  @@index([extractedFieldId])
  @@index([status])
}

model QuestionnaireResponse {
  id              String           @id
  promptKey       String
  taxYear         Int
  value           String
  answeredAt      DateTime         @default(now())
  sourceDocumentId String?
  sourceGapId     String?
  sourceDocument  ImportedDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceGap       DataGap?         @relation(fields: [sourceGapId], references: [id], onDelete: SetNull)

  @@index([promptKey, taxYear])
  @@index([sourceDocumentId])
  @@index([sourceGapId])
}

model AuditRun {
  id                   String                 @id
  workflow             String
  task                 String?
  actor                String
  status               String
  repoPath             String?
  worktreePath         String
  startedAt            DateTime
  completedAt          DateTime?
  durationMs           Int?
  executionCount       Int                    @default(0)
  failedExecutionCount Int                    @default(0)
  latestEventAt        DateTime?
  statsByKindJson      String?
  statsByStatusJson    String?
  summaryJson          String?
  events               AuditEventRecord[]
  executions           AuditExecutionRecord[]

  @@index([workflow, startedAt])
  @@index([status, startedAt])
  @@index([worktreePath, startedAt])
  @@index([latestEventAt])
}

model AuditExecutionRecord {
  id                String                 @id
  runId             String
  parentExecutionId String?
  kind              String
  name              String
  step              String?
  status            String
  startedAt         DateTime
  completedAt       DateTime?
  durationMs        Int?
  exitCode          Int?
  errorName         String?
  errorMessage      String?
  commandJson       String?
  metadataJson      String?
  logFile           String?
  run               AuditRun               @relation(fields: [runId], references: [id], onDelete: Cascade)
  parent            AuditExecutionRecord?  @relation("AuditExecutionHierarchy", fields: [parentExecutionId], references: [id], onDelete: SetNull)
  children          AuditExecutionRecord[] @relation("AuditExecutionHierarchy")
  events            AuditEventRecord[]

  @@index([runId, startedAt])
  @@index([kind, startedAt])
  @@index([status, startedAt])
  @@index([parentExecutionId])
}

model AuditEventRecord {
  id                String                @id
  runId             String
  executionId       String?
  eventType         String
  actor             String
  cwd               String
  status            String?
  step              String?
  task              String?
  timestamp         DateTime
  durationMs        Int?
  exitCode          Int?
  errorName         String?
  errorMessage      String?
  logFile           String?
  commandJson       String?
  metadataJson      String?
  executionKind     String?
  executionName     String?
  parentExecutionId String?
  workflow          String
  run               AuditRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  execution         AuditExecutionRecord? @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([runId, timestamp])
  @@index([executionId, timestamp])
  @@index([timestamp])
  @@index([workflow, timestamp])
}
